# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# NOTION_API_KEY: Your Notion internal integration token
NOTION_API_KEY="YOUR_NOTION_API_KEY"

# NOTION_DATABASE_ID: The Notion database ID for the Quest Code tracker
NOTION_DATABASE_ID="YOUR_NOTION_DATABASE_ID"

# GITHUB_TOKEN: For GitHub API integrations (optional)
GITHUB_TOKEN="YOUR_GITHUB_TOKEN"
